{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=fitquest_sync;Username=postgres;Password=postgres"
  },
  "JwtSettings": {
    "SecretKey": "your-secret-key-change-in-production",
    "Issuer": "fitquest",
    "Audience": "fitquest-app"
  },
  "Sync": {
    "MaxRetries": 4,
    "ProcessingIntervalSeconds": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
